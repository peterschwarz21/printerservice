# Your Twilio Auth Token (from https://console.twilio.com)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Your Twilio phone number in E.164 format (e.g. +15551234567)
TWILIO_PHONE_NUMBER=+15551234567

# Comma-separated list of phone numbers allowed to print (E.164 format)
# e.g. ALLOWED_NUMBERS=+15559876543,+15550001111
ALLOWED_NUMBERS=+15559876543

# Port for the local webhook server
PORT=3000

# URL of the thermal printer service
PRINTER_URL=http://printer-server
