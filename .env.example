# ---------------------------------------------------------------------------
# Shared config for ALL services (Node webhook, cron jobs, Python print server)
# Copy to .env and fill in your values. Never commit .env.
# ---------------------------------------------------------------------------

# --- Twilio ---
# Auth token from https://console.twilio.com (used to validate webhooks)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Your Twilio number in E.164 format (informational; not required by the server)
TWILIO_PHONE_NUMBER=+15551234567
# Comma-separated E.164 numbers allowed to print
ALLOWED_NUMBERS=+15559876543

# --- SMS webhook server (src/server.js) ---
PORT=3000

# --- Printer endpoint (shared by the webhook + the cron jobs) ---
PRINTER_URL=http://localhost:5000/print

# --- Print server (printer/print_server.py) ---
# Find your printer's IDs with `lsusb` (idVendor:idProduct), prefix each with 0x.
PRINTER_VENDOR_ID=0x0483
PRINTER_PRODUCT_ID=0x5743
PRINTER_PORT=5000

# --- Weather job (weather.js) ---
# Example: Denver, CO. Set to your own location.
WEATHER_LAT=39.7392
WEATHER_LON=-104.9903
WEATHER_TIMEZONE=America/Denver
