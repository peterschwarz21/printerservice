version: "3"
agent:
  # Get this from https://dashboard.ngrok.com/get-started/your-authtoken
  authtoken: YOUR_NGROK_AUTHTOKEN
tunnels:
  printer:
    addr: 3000
    proto: http
    # Claim a free static domain at https://dashboard.ngrok.com/domains
    # so your Twilio webhook URL never changes.
    domain: your-name.ngrok-free.app
